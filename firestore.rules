rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----- Funções auxiliares -----
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && currentUser().data.tipo == 'admin';
    }

    function isColab() {
      return isSignedIn() &&
        (currentUser().data.tipo == 'colaborador' || currentUser().data.tipo == 'admin');
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == userId || isAdmin());

      allow update: if isSignedIn() &&
        (request.auth.uid == userId || isAdmin());

      allow delete: if isAdmin();

      allow create: if isSignedIn();
    }

    match /users/{userId}/addresses/{addressId} {
      allow read, write: if isSignedIn() &&
        (request.auth.uid == userId || isAdmin());
    }

    // SERVICES
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isColab();
    }

    // BANNERS
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isColab();
    }

    // ORDERS (produção)
    match /orders/{orderId} {
      // criar só logado, e o userId do doc tem que ser o próprio usuário
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      // ler/atualizar:
      // - o dono do pedido
      // - colaborador/admin
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isColab()
      );
    }

    match /orders/{orderId}/files/{fileId} {
      allow read, write: if isSignedIn() && (
        resource.data.uploadedBy == request.auth.uid || isColab()
      );
    }

    match /orders/{orderId}/statusHistory/{statusId} {
      allow read: if isSignedIn() && (
        isColab() || resource.data.alteradoPor == request.auth.uid
      );
      allow write: if isColab();
    }

    // COUNTERS (geração de IDs sequenciais)
    match /counters/{counterId} {
      // Qualquer usuário autenticado pode ler e atualizar contadores de pedidos
      allow get, create, update: if isSignedIn() && counterId.matches('orders-.*');
      // Apenas admins podem deletar
      allow delete: if isAdmin();
    }

    // COUPONS
    match /coupons/{couponId} {
      allow read, write: if isColab();
    }

    // INVOICES
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() &&
        (resource.data.clienteId == request.auth.uid || isColab());
      allow write: if isColab();
    }

    match /financialEntries/{entryId} {
      allow read, write: if isColab();
    }

    // SECTORS
    match /sectors/{sectorId} {
      allow read, write: if isColab();
    }

    // CARTS
    match /carts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isColab();
    }
  }
}